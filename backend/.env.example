# UNEEDWHAT - ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your values
# DO NOT commit this file to version control

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment (development, staging, production)
NODE_ENV=development

# App name and version
APP_NAME=uneedwhat
APP_VERSION=1.0.0

# API Port
APP_PORT=3000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=uneedwhat
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSL=false

# Database connection pool
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Database logging
DATABASE_LOGGING=false
DATABASE_LOG_SLOW_QUERIES=true
DATABASE_SLOW_QUERY_THRESHOLD_MS=1000

# ============================================================================
# REDIS CACHE CONFIGURATION
# ============================================================================

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis options
REDIS_TLS=false
REDIS_POOL_MIN=1
REDIS_POOL_MAX=10

# Cache TTL (in seconds)
CACHE_TTL_JOB_LISTINGS=600           # 10 minutes
CACHE_TTL_USER_PROFILE=300           # 5 minutes
CACHE_TTL_JOB_ANALYTICS=1800         # 30 minutes
CACHE_TTL_SESSION=86400             # 24 hours

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_REFRESH_EXPIRATION=30d

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback

# Session Configuration
SESSION_SECRET=your-session-secret-change-this
SESSION_TIMEOUT=86400000              # 24 hours in milliseconds

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000          # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100          # Max requests per window
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false
RATE_LIMIT_SKIP_FAILED_REQUESTS=false

# Password Configuration
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

# Email Service Provider (gmail, sendgrid, aws-ses)
EMAIL_PROVIDER=sendgrid

# SMTP Configuration (for Gmail, Outlook, etc.)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false                    # Use TLS
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# SendGrid Configuration
SENDGRID_API_KEY=

# AWS SES Configuration
AWS_SES_REGION=us-east-1

# Email Settings
MAIL_FROM=noreply@uneedwhat.com
MAIL_FROM_NAME=uneedwhat

# Email Templates
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_APPLICATION_EMAIL=true
ENABLE_INTERVIEW_EMAIL=true
ENABLE_OFFER_EMAIL=true

# ============================================================================
# FILE UPLOAD & STORAGE
# ============================================================================

# File Storage Provider (local, aws-s3, gcs)
FILE_STORAGE_PROVIDER=aws-s3

# Local Storage
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE=52428800             # 50MB in bytes

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=uneedwhat-uploads
AWS_S3_ACL=private
AWS_S3_CDN_URL=https://cdn.uneedwhat.com

# Google Cloud Storage Configuration
GCS_PROJECT_ID=
GCS_BUCKET=
GCS_KEYFILE=./credentials.json

# Allowed file types for uploads
ALLOWED_FILE_TYPES=pdf,doc,docx,txt
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================

# Error Tracking (Sentry)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACE_SAMPLE_RATE=0.1

# Analytics (Google Analytics, Mixpanel, etc.)
GOOGLE_ANALYTICS_ID=
SEGMENT_WRITE_KEY=

# Monitoring (DataDog, New Relic)
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_ENVIRONMENT=development

# APM Monitoring
APM_ENABLED=false
APM_SERVICE_NAME=uneedwhat-backend
APM_ENVIRONMENT=development

# Logging Service
LOG_LEVEL=info                        # error, warn, info, debug
LOG_FORMAT=json                       # json or pretty
ENABLE_REQUEST_LOGGING=true
ENABLE_DATABASE_LOGGING=false

# ============================================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================================

# Video Conferencing (Zoom, Jitsi, etc.)
VIDEO_CONFERENCE_PROVIDER=zoom
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# SMS Service (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Payment Processing (Stripe)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================================================
# FRONTEND CONFIGURATION (Backend perspective)
# ============================================================================

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,https://yourdomain.com
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Frontend URL (for links in emails, etc.)
FRONTEND_URL=http://localhost:5173
FRONTEND_DOMAIN=yourdomain.com

# ============================================================================
# ADVANCED FEATURES
# ============================================================================

# Feature Flags
ENABLE_FILE_UPLOAD=true
ENABLE_VIDEO_INTERVIEW=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_RESUME_PARSING=true
ENABLE_AI_MATCHING=true
ENABLE_BULK_IMPORT=true

# AI Integration (for resume parsing, job matching)
AI_SERVICE_PROVIDER=anthropic        # anthropic, openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ============================================================================
# WORKER CONFIGURATION (Background Jobs)
# ============================================================================

# Bull Queue (Job Queue)
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=

# Job Processing
ENABLE_JOB_QUEUE=true
JOB_QUEUE_CONCURRENCY=5

# Job Types to process
ENABLE_EMAIL_JOBS=true
ENABLE_PDF_JOBS=true
ENABLE_NOTIFICATION_JOBS=true
ENABLE_ANALYTICS_JOBS=true

# ============================================================================
# DATABASE BACKUP & MAINTENANCE
# ============================================================================

# Automatic Backups
ENABLE_BACKUPS=true
BACKUP_SCHEDULE=0 2 * * *             # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# Database Maintenance
ENABLE_VACUUM=true
VACUUM_SCHEDULE=0 3 * * *             # Daily at 3 AM
ENABLE_REINDEX=false
REINDEX_SCHEDULE=0 4 * * 0            # Weekly Sunday at 4 AM

# ============================================================================
# TESTING & DEVELOPMENT
# ============================================================================

# Test Database
TEST_DATABASE_HOST=localhost
TEST_DATABASE_NAME=uneedwhat_test
TEST_DATABASE_USER=postgres
TEST_DATABASE_PASSWORD=postgres

# Test Configuration
NODE_ENV=test
ENABLE_SEEDING=true
CLEAR_DATA_BEFORE_TESTS=true

# Debug Mode
DEBUG=false
DEBUG_SQL=false

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================

# API Performance
API_CACHE_ENABLED=true
API_COMPRESSION_ENABLED=true
API_COMPRESSION_LEVEL=6

# Database Performance
DATABASE_ENABLE_QUERY_CACHE=true
DATABASE_SLOW_QUERY_LOGGING=true
DATABASE_SLOW_QUERY_THRESHOLD_MS=1000

# Worker Performance
WORKER_POOL_SIZE=10
WORKER_MAX_QUEUE_SIZE=1000

# ============================================================================
# COMPLIANCE & SECURITY
# ============================================================================

# GDPR Compliance
GDPR_ENABLED=true
ENABLE_DATA_EXPORT=true
ENABLE_DATA_DELETION=true
DATA_RETENTION_DAYS=2555             # ~7 years

# HIPAA Compliance (if applicable)
HIPAA_ENABLED=false

# SOC2 Compliance
SOC2_ENABLED=false

# Encryption
ENCRYPTION_KEY=your-encryption-key-32-chars-min
ENABLE_FIELD_ENCRYPTION=false

# ============================================================================
# DEPLOYMENT SPECIFICS
# ============================================================================

# Infrastructure Provider (aws, gcp, azure, heroku)
INFRASTRUCTURE_PROVIDER=aws
DEPLOYMENT_ENVIRONMENT=development

# Container Registry
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE=manucian-official/uneedwhat

# Kubernetes (if applicable)
KUBERNETES_NAMESPACE=default
KUBERNETES_CLUSTER_NAME=

# ============================================================================
# FRONTEND (.env) CONFIGURATION
# ============================================================================

# API Configuration
VITE_APP_NAME=uneedwhat
VITE_API_URL=http://localhost:3000/api/v1
VITE_API_TIMEOUT=30000
VITE_WS_URL=ws://localhost:3000

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_VIDEO_INTERVIEW=true
VITE_ENABLE_RESUME_UPLOAD=true

# Third-party Services
VITE_GOOGLE_ANALYTICS_ID=
VITE_SENTRY_DSN=
VITE_GOOGLE_MAPS_API_KEY=

# ============================================================================
# NOTES
# ============================================================================

# 1. Generate secure random strings:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 2. For production, use secrets management:
#    - AWS Secrets Manager
#    - HashiCorp Vault
#    - Azure Key Vault
#    - Kubernetes Secrets
#
# 3. Never commit .env files with real secrets
# 4. Use .env.example for template
# 5. Keep secrets out of logs and error messages
# 6. Rotate secrets regularly
# 7. Use different secrets for each environment
# 8. Document all environment variables
# 9. Validate environment variables on startup
# 10. Never hardcode secrets in code
