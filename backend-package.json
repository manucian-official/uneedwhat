{
  "name": "uneedwhat-backend",
  "version": "1.0.0",
  "description": "Modern recruitment platform backend - NestJS with TypeORM and PostgreSQL",
  "author": "Khôi Manucian <khoi@uneedwhat.com>",
  "license": "MIT",
  "main": "dist/main.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:integration": "jest --config ./test/jest-integration.json",
    "db:create": "typeorm database create",
    "db:drop": "typeorm database drop",
    "db:migrate": "typeorm migration:run -d src/database/data-source.ts",
    "db:migrate:revert": "typeorm migration:revert -d src/database/data-source.ts",
    "db:migrate:show": "typeorm migration:show -d src/database/data-source.ts",
    "db:migrate:create": "typeorm migration:create",
    "db:schema:sync": "typeorm schema:sync -d src/database/data-source.ts",
    "db:schema:drop": "typeorm schema:drop -d src/database/data-source.ts",
    "db:seed": "nest start --entryFile \"database/seeders/main\"",
    "db:seed:custom": "ts-node src/database/seeders/main.ts",
    "db:backup": "pg_dump -h $DATABASE_HOST -U $DATABASE_USER -d $DATABASE_NAME > backup-$(date +%Y%m%d-%H%M%S).sql",
    "db:restore": "pg_restore -h $DATABASE_HOST -U $DATABASE_USER -d $DATABASE_NAME $1",
    "cache:clear": "redis-cli FLUSHALL",
    "cache:stats": "redis-cli INFO",
    "typeorm": "typeorm",
    "docker:build": "docker build -t uneedwhat-backend:latest -f docker/Dockerfile .",
    "docker:build:prod": "docker build -t uneedwhat-backend:prod --target production -f docker/Dockerfile.multi .",
    "docker:run": "docker run -p 3000:3000 --env-file .env uneedwhat-backend:latest",
    "docker:compose:up": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "docker:compose:logs": "docker-compose logs -f",
    "health": "curl http://localhost:3000/api/v1/health",
    "generate:docs": "compodoc -p tsconfig.json -d docs",
    "generate:coverage": "jest --coverage && open coverage/index.html",
    "audit:security": "npm audit",
    "audit:security:fix": "npm audit fix",
    "dependencies:update": "npm update",
    "dependencies:check": "npm outdated"
  },
  "dependencies": {
    "@nestjs/bull": "^10.0.0",
    "@nestjs/common": "^10.2.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.2.0",
    "@nestjs/jwt": "^10.1.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.2.0",
    "@nestjs/schedule": "^3.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/throttler": "^4.0.0",
    "@nestjs/typeorm": "^9.0.0",
    "@nestjs/websockets": "^10.2.0",
    "@sentry/node": "^7.80.0",
    "aws-sdk": "^2.1500.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.11.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.10",
    "dotenv": "^16.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "mailgun.js": "^9.2.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pino": "^8.17.1",
    "pino-pretty": "^10.3.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^5.0.5",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.2",
    "stripe": "^13.10.0",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@compodoc/compodoc": "^1.1.19",
    "@nestjs/cli": "^10.2.1",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^4.11.4",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.1",
    "@types/nodemailer": "^6.4.14",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/passport-jwt": "^3.0.13",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>",
      "<rootDir>/../test"
    ],
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    }
  },
  "keywords": [
    "recruitment",
    "job-board",
    "nestjs",
    "typescript",
    "postgresql",
    "redis",
    "job-matching",
    "hr-platform"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/manucian-official/uneedwhat"
  },
  "bugs": {
    "url": "https://github.com/manucian-official/uneedwhat/issues"
  },
  "homepage": "https://github.com/manucian-official/uneedwhat"
}
