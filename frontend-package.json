{
  "name": "uneedwhat-frontend",
  "version": "1.0.0",
  "description": "Modern recruitment platform frontend - React 18 with Vite and TypeScript",
  "author": "Khôi Manucian <khoi@uneedwhat.com>",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "test:unit": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "analyze": "vite-bundle-visualizer",
    "analyze:build": "npm run build && vite-bundle-visualizer dist",
    "optimize:images": "imagemin src/assets/images/**/*.{jpg,jpeg,png} --out-dir=src/assets/images/optimized",
    "docker:build": "docker build -t uneedwhat-frontend:latest -f docker/Dockerfile .",
    "docker:build:prod": "docker build -t uneedwhat-frontend:prod --target production -f docker/Dockerfile.multi .",
    "docker:run": "docker run -p 5173:5173 uneedwhat-frontend:latest",
    "docker:compose:up": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "audit:security": "npm audit",
    "audit:security:fix": "npm audit fix",
    "dependencies:update": "npm update",
    "dependencies:check": "npm outdated",
    "generate:icons": "vite-plugin-icons --out src/components/icons",
    "lighthouse": "lighthouse http://localhost:5173 --view"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-form": "^0.0.26",
    "@radix-ui/react-hover-card": "^1.0.7",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^2.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@sentry/react": "^7.80.0",
    "axios": "^1.6.2",
    "chart.js": "^4.4.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "dayjs": "^1.11.10",
    "framer-motion": "^10.16.4",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.292.0",
    "next-auth": "^4.24.7",
    "papaparse": "^5.4.1",
    "passport": "^0.7.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.48.0",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^4.12.0",
    "react-query": "^3.39.3",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.3",
    "socket.io-client": "^4.7.2",
    "sonner": "^1.2.3",
    "tailwind-merge": "^2.2.0",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-radix-colors": "^2.4.1",
    "uuid": "^9.0.1",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^1.2.39",
    "@playwright/test": "^1.40.1",
    "@storybook/addon-essentials": "^7.6.3",
    "@storybook/addon-interactions": "^7.6.3",
    "@storybook/addon-links": "^7.6.3",
    "@storybook/addon-onboarding": "^7.6.3",
    "@storybook/blocks": "^7.6.3",
    "@storybook/react": "^7.6.3",
    "@storybook/react-vite": "^7.6.3",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20.10.1",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.0.4",
    "autoprefixer": "^10.4.16",
    "chromatic": "^11.0.6",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "imagemin": "^8.0.1",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^9.0.2",
    "lighthouse": "^11.4.0",
    "postcss": "^8.4.32",
    "prettier": "^3.1.0",
    "storybook": "^7.6.3",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.7",
    "vite-bundle-visualizer": "^0.10.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-environment": "^1.1.3",
    "vite-plugin-imagemin": "^0.6.1",
    "vitest": "^1.0.4"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "keywords": [
    "recruitment",
    "job-board",
    "react",
    "typescript",
    "tailwind-css",
    "vite",
    "job-matching",
    "hr-platform"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/manucian-official/uneedwhat"
  },
  "bugs": {
    "url": "https://github.com/manucian-official/uneedwhat/issues"
  },
  "homepage": "https://github.com/manucian-official/uneedwhat"
}
